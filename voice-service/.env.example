ZETTEL_API_URL=http://localhost:5000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Nova Sonic model configuration
BEDROCK_MODEL_ID=amazon.nova-sonic-v2:0
NOVA_SONIC_VOICE=matthew
NOVA_SONIC_VAD_SENSITIVITY=MEDIUM
NOVA_SONIC_MAX_TOKENS=2048
NOVA_SONIC_TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO

# OpenTelemetry — leave unset to disable OTLP export (telemetry still configured internally)
# OTEL_ENDPOINT=http://localhost:4317
